{
  "name": "lf-automatizador",
  "productName": "LF Automatizador",
  "version": "0.9.0",
  "description": "Software de Automatizacion de Radio",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "author": "Luis Fernando",
  "license": "ISC",
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "electron": "^41.7.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "ffmpeg-static": "^5.3.0",
    "fuse.js": "^7.3.0",
    "node-id3": "^0.2.9"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "build": {
    "appId": "com.lfautomatizador.app",
    "productName": "LF Automatizador",
    "directories": {
      "output": "dist"
    },
    "asarUnpack": [
      "node_modules/ffmpeg-static/**/*",
      "bin/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "Documentación/guia_primer_uso.jpg"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "AudioVideo",
      "icon": "Documentación/guia_primer_uso.jpg"
    }
  }
}
